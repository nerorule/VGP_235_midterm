<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserActivity">

    <ImageView
        android:id="@+id/Background_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/background" />

    <TextView
        android:id="@+id/textViewOcupation"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="92dp"
        android:text="Ocupation:"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView2" />

    <TextView
        android:id="@+id/textViewBodyType"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginTop="9dp"
        android:layout_marginEnd="19dp"
        android:text="BodyType:"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewHairColor_id" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="212dp"
        android:layout_height="193dp"
        android:layout_marginStart="7dp"
        android:layout_marginTop="106dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/anime" />

    <TextView
        android:id="@+id/textViewName_id"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView2" />

    <TextView
        android:id="@+id/textViewEyeColor_id"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="19dp"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewEye_Hair" />

    <TextView
        android:id="@+id/textViewHairColor_id"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="16dp"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewEye_Hair" />

    <TextView
        android:id="@+id/textViewOcupation_id"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="124dp"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView2" />

    <TextView
        android:id="@+id/textViewName"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:text="Name:"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView2" />

    <TextView
        android:id="@+id/textViewEye_Hair"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"
        android:text="Eye/Hair:"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewAge_id" />

    <TextView
        android:id="@+id/textViewAge_id"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="256dp"
        android:textSize="24sp"
        app:layout_constraintStart_toEndOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewHeight_id"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="152dp"
        android:textSize="24sp"
        app:layout_constraintStart_toEndOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewBodyType_id"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="16dp"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewHairColor_id" />

    <TextView
        android:id="@+id/textViewWeight_id"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="184dp"
        android:textSize="24sp"
        app:layout_constraintStart_toEndOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewAge"
        android:layout_width="172dp"
        android:layout_height="34dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="220dp"
        android:text="Age:"
        android:textSize="24sp"
        app:layout_constraintStart_toEndOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewWeight_Height"
        android:layout_width="188dp"
        android:layout_height="35dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="120dp"
        android:text="Height/Weight:"
        android:textSize="24sp"
        app:layout_constraintStart_toEndOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/line"
        android:layout_width="wrap_content"
        android:layout_height="10dp"
        android:layout_marginTop="52dp"
        android:background="#F5BECE"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/Heartimage" />

    <ImageView
        android:id="@+id/Heartimage"
        android:layout_width="111dp"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="148dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewBodyType_id"
        app:srcCompat="@drawable/heart" />

    <TextView
        android:id="@+id/textView_Porcentage_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="217dp"
        android:layout_marginBottom="48dp"
        android:text="%"
        app:layout_constraintBottom_toBottomOf="@+id/Heartimage"
        app:layout_constraintEnd_toEndOf="@+id/line"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>